PORT=3001
CLIENT_URL=http://localhost:5173
ADMIN_DASHBOARD_URL=http://localhost:5173/chat

# Notification channel used by the backend.
# Current implementation supports telegram.
NOTIFY_CHANNEL=telegram

# Telegram notifications for the live chat.
# Leave empty to disable Telegram notifications locally.
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
